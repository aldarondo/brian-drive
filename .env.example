# Google Service Account JSON path (recommended for NAS deployment)
GOOGLE_SERVICE_ACCOUNT_JSON=/run/secrets/google-sa.json

# OR inline base64-encoded JSON (alternative for Docker env var injection)
# GOOGLE_SERVICE_ACCOUNT_BASE64=<base64 of service account JSON>

# Google Drive folder ID to watch
# Get from the folder URL: drive.google.com/drive/folders/<FOLDER_ID>
WATCH_FOLDER_ID=your_folder_id

# Poll interval in seconds (default: 60)
POLL_INTERVAL_SECONDS=60

# brian-mem MCP endpoint for storing parsed results
BRIAN_MEM_URL=http://localhost:3001

# Anthropic API key — required for image OCR (HEIC/JPG/PNG processor)
# If not set, image files are skipped with a log warning
ANTHROPIC_API_KEY=

# Webhook mode (optional — replaces polling with Google Drive Push Notifications)
# Requires a publicly reachable HTTPS URL (e.g. via Cloudflare Tunnel)
# WEBHOOK_URL=https://your-tunnel.example.com/webhook
# WEBHOOK_PORT=8776
